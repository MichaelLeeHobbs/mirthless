# ===================
# Application
# ===================
NODE_ENV=development
PORT=3000

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:5173

# ===================
# Database
# ===================
DATABASE_URL=postgresql://mirthless:mirthless_dev@localhost:5432/mirthless
DATABASE_SSL=false

# ===================
# Authentication
# ===================
JWT_SECRET=your-super-secret-key-change-in-production-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===================
# Logging
# ===================
LOG_LEVEL=debug
# Set to 'true' to log HTTP headers (useful for debugging, but can expose sensitive information)
# Note: authorization/cookie/set-cookie and known secret fields are always redacted.
LOG_HTTP_HEADERS=false

# ===================
# Security / Observability
# ===================
# At-rest message content encryption key (AES-256-GCM). 64 hex chars = 32 bytes.
# Optional; required only once at-rest encryption (encryptData) is wired.
# Generate: openssl rand -hex 32
# CONTENT_ENCRYPTION_KEY=
# Expose /metrics without auth (for a network-isolated Prometheus scraper). Default protected.
METRICS_PUBLIC=false
# Serve Swagger UI at /api-docs. Defaults on outside production; set true to force-enable.
# API_DOCS_ENABLED=true

# ===================
# Proxy
# ===================
# Trust proxy — set to 'true' or '1' behind a reverse proxy (nginx, ALB, etc.)
TRUST_PROXY=false

<channel version="4.5.0">
  <id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</id>
  <name>HL7 Inbound Listener</name>
  <description>Basic TCP listener for HL7 messages</description>
  <enabled>true</enabled>
  <sourceConnector version="4.5.0">
    <name>sourceConnector</name>
    <transportName>TCP Listener</transportName>
    <enabled>true</enabled>
    <properties class="com.mirth.connect.connectors.tcp.TcpReceiverProperties" version="4.5.0">
      <listenerConnectorProperties version="4.5.0">
        <host>0.0.0.0</host>
        <port>6661</port>
      </listenerConnectorProperties>
    </properties>
    <transformer version="4.5.0">
      <inboundDataType>HL7V2</inboundDataType>
      <outboundDataType>HL7V2</outboundDataType>
    </transformer>
  </sourceConnector>
  <destinationConnectors>
    <connector version="4.5.0">
      <name>HTTP Destination</name>
      <transportName>HTTP Sender</transportName>
      <enabled>true</enabled>
      <properties class="com.mirth.connect.connectors.http.HttpDispatcherProperties" version="4.5.0">
        <host>http://localhost:8080/api/receive</host>
      </properties>
      <transformer version="4.5.0">
        <inboundDataType>HL7V2</inboundDataType>
        <outboundDataType>HL7V2</outboundDataType>
      </transformer>
      <waitForPrevious>true</waitForPrevious>
    </connector>
  </destinationConnectors>
  <deployScript>logger.info('Channel deployed');</deployScript>
  <undeployScript>logger.info('Channel undeployed');</undeployScript>
  <properties>
    <initialState>STARTED</initialState>
    <messageStorageMode>DEVELOPMENT</messageStorageMode>
    <encryptData>false</encryptData>
    <removeContentOnCompletion>false</removeContentOnCompletion>
    <removeAttachmentsOnCompletion>false</removeAttachmentsOnCompletion>
  </properties>
</channel>

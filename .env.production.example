# ===========================================
# Mirthless Production Configuration
# ===========================================
# Copy to .env and fill in all values marked CHANGE_ME

# Application
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-domain.com

# Inbound connector listener port range published by the Docker prod stack.
# Source channels (TCP/MLLP, DICOM, raw HTTP) bind ports inside the container;
# publish the range your channels use so sending systems can reach them.
MLLP_PORT_RANGE=6661-6670

# Set TRUST_PROXY to the number of proxy hops in front of the app (e.g. 1 for a
# single nginx). Do NOT use 'true' in production — it trusts a client-supplied
# X-Forwarded-For, letting clients spoof their IP and bypass the auth rate limiter.

# Database (PostgreSQL 17)
# POSTGRES_PASSWORD is REQUIRED by docker-compose.prod.yml (no default —
# compose refuses to start without it). It also fills the password in
# DATABASE_URL, which the compose file builds for the server automatically.
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://mirthless:CHANGE_ME@db:5432/mirthless
DATABASE_SSL=false

# Authentication — CHANGE THESE!
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security / Observability
# At-rest content encryption key (AES-256-GCM, 64 hex chars). Optional until encryptData is wired.
# Generate: openssl rand -hex 32
# CONTENT_ENCRYPTION_KEY=
# /metrics requires auth unless METRICS_PUBLIC=true (use only with a network-isolated scraper).
METRICS_PUBLIC=false
# /api-docs is OFF in production unless explicitly enabled.
API_DOCS_ENABLED=false

# Logging
LOG_LEVEL=info
# Log inbound HTTP request headers (verbose; may capture auth headers — keep off in prod)
LOG_HTTP_HEADERS=false

# Reverse Proxy
# Set to 'true' if behind nginx/load balancer, or a number for hop count
TRUST_PROXY=1

# Startup
# The server container runs migrations then an idempotent seed on start.
# Set to 'false' to skip seeding (migrations always run).
SEED_ON_START=true
